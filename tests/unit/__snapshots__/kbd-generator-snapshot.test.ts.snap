exports[`kbd-generator snapshot tests > ANSI 104 デフォルト 1`] = `
";; Generated by kanata-web-config

(defcfg
  process-unmapped-keys yes
)

(defsrc
  esc f1 f2 f3 f4 f5 f6 f7 f8 f9 f10 f11 f12 prtsc slck pause
  grv 1 2 3 4 5 6 7 8 9 0 - = bspc ins home pgup nlck kp/ kp* kp-
  tab q w e r t y u i o p [ ] \\ del end pgdn kp7 kp8 kp9 kp+
  caps a s d f g h j k l ; ' ret kp4 kp5 kp6
  lsft z x c v b n m , . / rsft up kp1 kp2 kp3 kprt
  lctl lmet lalt spc ralt rmet comp rctl lft down rght kp0 kp.
)

(deflayer layer-0
  esc f1 f2 f3 f4 f5 f6 f7 f8 f9 f10 f11 f12 prtsc slck pause
  grv 1 2 3 4 5 6 7 8 9 0 - = bspc ins home pgup nlck kp/ kp* kp-
  tab q w e r t y u i o p [ ] \\ del end pgdn kp7 kp8 kp9 kp+
  caps a s d f g h j k l ; ' ret kp4 kp5 kp6
  lsft z x c v b n m , . / rsft up kp1 kp2 kp3 kprt
  lctl lmet lalt spc ralt rmet comp rctl lft down rght kp0 kp.
)
"
`;

exports[`kbd-generator snapshot tests > ANSI 104 複数レイヤー 1`] = `
";; Generated by kanata-web-config

(defcfg
  process-unmapped-keys yes
)

(defsrc
  esc f1 f2 f3 f4 f5 f6 f7 f8 f9 f10 f11 f12 prtsc slck pause
  grv 1 2 3 4 5 6 7 8 9 0 - = bspc ins home pgup nlck kp/ kp* kp-
